# =============================================================================
# Werco ERP - Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# See docs/ENVIRONMENT_VARIABLES.md for full documentation
#
# IMPORTANT: All frontend env vars MUST start with REACT_APP_
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (Required)
# -----------------------------------------------------------------------------
# Backend API URL - include the /api/v1 suffix
# Local development:
REACT_APP_API_URL=http://localhost:8000/api/v1

# Production examples:
# REACT_APP_API_URL=https://your-backend.up.railway.app/api/v1
# REACT_APP_API_URL=https://api.werco.com/api/v1

# -----------------------------------------------------------------------------
# E2E Testing (Optional - for Playwright tests)
# -----------------------------------------------------------------------------
# These MUST match users created by backend/scripts/seed_data.py. Run the suite
# with the backend rate limiter disabled (RATE_LIMIT_ENABLED=false) or the
# login-heavy tests trip the auth-login limit (5/min) and 429.

# Base URL Playwright targets (Vite dev server). Defaults to this when unset.
E2E_BASE_URL=http://localhost:5173

# Admin credentials for E2E tests
E2E_ADMIN_EMAIL=admin@werco.com
E2E_ADMIN_SECRET=admin123

# Manager credentials for E2E tests
E2E_MANAGER_EMAIL=jsmith@werco.com
E2E_MANAGER_SECRET=password123

# Operator credentials for E2E tests
E2E_OPERATOR_EMAIL=bwilliams@werco.com
E2E_OPERATOR_SECRET=password123
