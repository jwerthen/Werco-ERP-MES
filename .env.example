# =============================================================================
# Werco ERP - Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# See docs/ENVIRONMENT_VARIABLES.md for full documentation
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase)
# -----------------------------------------------------------------------------
# Use the Supabase Postgres connection string from Project Settings > Database.
DATABASE_URL=postgresql://postgres.meatfdvteugbeksckgqg:<your-supabase-db-pass>@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Optional pieces if you prefer the backend to build DATABASE_URL.
SUPABASE_URL=https://meatfdvteugbeksckgqg.supabase.co
SUPABASE_PROJECT_REF=meatfdvteugbeksckgqg
SUPABASE_DB_PASSWORD=<your-supabase-db-pass>

# -----------------------------------------------------------------------------
# Security - CRITICAL: Change these in production!
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-in-production-use-strong-random-key
REFRESH_TOKEN_SECRET_KEY=change-this-different-key-for-refresh-tokens

# -----------------------------------------------------------------------------
# External Services (Optional)
# -----------------------------------------------------------------------------
# Anthropic API Key for AI-powered PO extraction
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Sentry DSN for error tracking (optional)
# Get your DSN at https://sentry.io/
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# For Gmail: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@werco.com
SMTP_FROM_NAME=Werco ERP System

# -----------------------------------------------------------------------------
# Webhook Security (Optional)
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_ENCRYPTION_KEY=
