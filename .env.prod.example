# Production Environment Variables for Werco ERP
# Copy this file to .env.prod and fill in all values
# NEVER commit .env.prod to version control!

# ======================
# Database Configuration (Supabase)
# ======================
DATABASE_URL=postgresql://postgres.meatfdvteugbeksckgqg:<SUPABASE_DB_PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres
DATABASE_PROVIDER=supabase

# Optional aliases used by some deployment providers and Supabase integrations.
# These override a non-Supabase DATABASE_URL if one is injected by the platform.
SUPABASE_DATABASE_URL=
SUPABASE_POSTGRES_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
DIRECT_URL=

# Optional pieces if you prefer the backend to build DATABASE_URL.
SUPABASE_URL=https://meatfdvteugbeksckgqg.supabase.co
SUPABASE_PROJECT_REF=meatfdvteugbeksckgqg
SUPABASE_DB_PASSWORD=<SUPABASE_DB_PASSWORD>

# ======================
# Security Keys
# ======================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<GENERATE_64_CHAR_SECRET>
REFRESH_TOKEN_SECRET_KEY=<GENERATE_DIFFERENT_64_CHAR_SECRET>

# ======================
# Redis Configuration
# ======================
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD_32_CHARS>

# ======================
# CORS Configuration
# ======================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://erp.yourcompany.com

# ======================
# Trusted Hosts (HTTP Host header)
# ======================
# Host-header allowlist (TrustedHostMiddleware). Default "*" disables validation;
# in production set the API's real hostnames AND the health-check probe hosts
# (localhost for the container HEALTHCHECK, healthcheck.railway.app on Railway) or
# health checks return 400 and the deploy is marked unhealthy.
# See docs/ENVIRONMENT_VARIABLES.md#trusted-hosts-http-host-header
ALLOWED_HOSTS=api.werco.com,erp.werco.com,*.up.railway.app,healthcheck.railway.app,localhost

# ======================
# Frontend Configuration
# ======================
REACT_APP_API_URL=https://erp.yourcompany.com/api/v1

# ======================
# Email Configuration
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASSWORD=<APP_SPECIFIC_PASSWORD>
SMTP_FROM=notifications@yourcompany.com
SMTP_FROM_NAME=Werco ERP System

# ======================
# External Services
# ======================
# Anthropic API (for AI features)
ANTHROPIC_API_KEY=
# Model selection: auto chooses the lowest-cost tier likely to be reliable.
# Set to fast, default, reasoning, or a specific model ID to force behavior.
ANTHROPIC_MODEL_SELECTION=auto
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-opus-4-8
# Optional task-specific overrides. Leave blank for automatic routing.
ANTHROPIC_BOM_MODEL=
ANTHROPIC_PO_MODEL=
ANTHROPIC_ROUTING_MODEL=
ANTHROPIC_QMS_MODEL=

# Sentry (error tracking)
SENTRY_DSN=

# Webhook encryption
WEBHOOK_ENCRYPTION_KEY=

# ======================
# Version/Deployment
# ======================
VERSION=1.0.0

# ======================
# Performance Tuning
# ======================
# Gunicorn workers (recommended: 2-4 x CPU cores)
GUNICORN_WORKERS=4
